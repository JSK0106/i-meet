    <script>
        const ClassInfoModal = document.getElementById('ClassInfo_modal');
        const ClassInfoModifyModal = document.getElementById('ClassInfo_modify_modal');
        const modalModifyBtn = document.getElementById('modalModifyBtn');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const modalCancelBtn = document.getElementById('modalCancelBtn');
        const modalCloseBtn2 = document.getElementById('modalCloseBtn2');
        const modalCancelBtn2 = document.getElementById('modalCancelBtn2');
        const classTypes = document.querySelectorAll('#class_type');
        const classPlus = document.getElementById('class_plus');

        // 모든 class_type 요소에 클릭 이벤트 추가
        classTypes.forEach(classType => {
            classType.addEventListener('click', () => {
                ClassInfoModal.style.display = 'flex';
            });
        });

        // 수정 버튼 클릭 시 수정 모달 열기, 원래 모달 닫기
        modalModifyBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            ClassInfoModal.style.display = 'none';
            ClassInfoModifyModal.style.display = 'flex';
        });

        // 추가 버튼 클릭 시 수정 모달 열기
        classPlus?.addEventListener('click', () => {
            ClassInfoModifyModal.style.display = 'flex';
        });

        // 각 닫기 버튼에 이벤트 추가
        modalCloseBtn?.addEventListener('click', () => {
            ClassInfoModal.style.display = 'none';
        });
        modalCancelBtn?.addEventListener('click', () => {
            ClassInfoModal.style.display = 'none';
        });
        modalCloseBtn2?.addEventListener('click', () => {
            ClassInfoModifyModal.style.display = 'none';
        });
        modalCancelBtn2?.addEventListener('click', () => {
            ClassInfoModifyModal.style.display = 'none';
        });

        // 모달 외부 영역 클릭 시 닫기
        window.addEventListener('click', (e) => {
            if (e.target === ClassInfoModal || e.target === ClassInfoModifyModal) {
                ClassInfoModal.style.display = 'none';
                ClassInfoModifyModal.style.display = 'none';
            }
        });
    </script>
