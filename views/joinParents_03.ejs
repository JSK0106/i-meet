            "제주특별자치도": ["서귀포시", "제주시"]
        };

        const address01 = document.getElementById('address01');
        const address02 = document.getElementById('address02');

        address01.addEventListener('change', function() {
            const selected = this.value;
            const cities = areaList[selected];

            // 기존 옵션 비우기
            address02.innerHTML = '<option disabled selected>시/군구</option>';

            if (cities) {
                cities.forEach(function(city) {
                    const option = document.createElement('option');
                    option.value = city;
                    option.textContent = city;
                    address02.appendChild(option);
                });
            }
        });

        //btn_active 추가
        const buttons = document.querySelectorAll('.btn_blueline02');

        buttons.forEach(button => {
            button.addEventListener('click', function() {
                // 나머지 버튼들에서 btn_active 제거
                buttons.forEach(btn => {
                    if (btn !== this) {
                        btn.classList.remove('btn_active');
                    }
                });

                // 자기 자신은 토글
                this.classList.toggle('btn_active');
            });
        });
