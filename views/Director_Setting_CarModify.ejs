    <script>
        // 삭제 버튼 클릭
        document.addEventListener('click', function(event) {
            if (event.target.closest('.form_delete')) {
                const btn = event.target.closest('.form_delete');
                const classWrap = btn.closest('.car');
                const parent = classWrap.parentElement; // .info_wrap02

                const allClassWraps = parent.querySelectorAll('.car');
                if (allClassWraps.length > 1) {
                    classWrap.remove(); // 하나 이상이면 삭제
                } else {
                    alert('차량 정보는 최소 1개 이상 필요합니다.');
                }
            }
        });
        
        // 추가 버튼 클릭
        document.getElementById('btn_add').addEventListener('click', function() {
            const parent = document.getElementById('car_info');
            const noticeList = parent.querySelectorAll('.car');
            const lastNotice = noticeList[noticeList.length - 1]; // 가장 마지막 항목 복제
            const clone = lastNotice.cloneNode(true);

            // 복제한 input 초기화
            const input = clone.querySelector('input');
            if (input) {
                input.value = '';
                input.removeAttribute('id'); // 중복 id 제거
            }

            // label의 숫자 증가
            const label = clone.querySelector('label span');
            if (label) {
                label.textContent = String(noticeList.length + 1).padStart(2, '0');
            }

            parent.insertBefore(clone, this); // '추가' 버튼 앞에 삽입
        });
    </script>
