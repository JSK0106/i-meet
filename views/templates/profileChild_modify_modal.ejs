<div class="modal_con">
    <!-- modal header -->
    <div class="modal_header flex_between">
        <h2 class="h2_G_type02">원아 등록</h2>
        <button id="modalCloseBtn2" class="btn_x_modal">
            <span class="blind">모달창 닫기</span>
        </button>
    </div>

    <!-- modal body -->
    <div class="modal_body">
        <div class="form_wrap modal_01 flex_start2">
            <!-- 프로필 이미지 업로드 -->
            <div id="profile_img" class="form_request flex_center">
                <div class="upload_btn">
                    <input type="file" id="file_input" accept="image/*" style="display: none;">
                    <button id="profile_img_upload" type="button" class="modal_btn_blue02 flex_center">
                        <div class="icon_upload"><span class="blind">업로드 아이콘</span></div>
                        <p class="p_16px">이미지 등록하기</p>
                    </button>
                </div>
            </div>

            <!-- 프로필 정보 -->
            <div id="profile_info" class="form_request flex_start_column">
                <div class="form_text flex_start_column">
                    <label for="이름">이름</label>
                    <input id="child_name" type="text" placeholder="원아의 이름을 입력하세요">
                </div>
                <div class="form_text flex_start_column">
                    <label for="생년월일">생년월일</label>
                    <input id="child_birth" type="text" placeholder="생년월일 8자리를 입력하세요">
                </div>
                <div class="form_select flex_start_column">
                    <label for="성별">성별</label>
                    <select name="child_sex" class="select_01">
                        <option disabled selected>선택</option>
                        <option value="남">남</option>
                        <option value="여">여</option>
                    </select>
                </div>
                <div class="form_select flex_start_column">
                    <label for="반">반</label>
                    <select name="child_class" class="select_01">
                        <option disabled selected>선택</option>
                        <option value="햇님반">햇님반</option>
                        <option value="달님반">달님반</option>
                        <option value="별님반">별님반</option>
                    </select>
                </div>
                <div class="form_select02 flex_start_column">
                    <div class="flex_between">
                        <label for="보호자">보호자</label>
                        <button type="button" class="btn_plus">
                            <span class="blind">보호자 추가</span>
                        </button>
                    </div>
                    <div id="third_input" class="flex_start">
                        <div>
                            <div class="flex_start">
                                <select name="parents_relation" class="select_02">
                                    <option disabled selected>관계</option>
                                    <option value="부">부</option>
                                    <option value="모">모</option>
                                    <option value="조부">조부</option>
                                    <option value="조모">조모</option>
                                    <option value="기타">기타</option>
                                </select>
                                <input id="parents_name" type="text" class="Text_input02" placeholder="보호자 이름을 입력하세요">
                            </div>
                            <input id="parents_phone" type="text" class="input_02" placeholder="보호자의 휴대폰 번호를 입력하세요">
                        </div>
                        <button type="button" class="btn_delete">
                            <span class="blind">삭제</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 하단 버튼 -->
    <div class="modal_btn_wrap flex_center">
        <li>
            <button type="button" id="modalRegisterBtn" class="modal_btn_blue01">등록</button>
        </li>
        <li>
            <button type="button" id="modalCancelBtn2" class="modal_btn_blueline01">닫기</button>
        </li>
    </div>
</div>