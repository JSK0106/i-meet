<!-- 모바일 메뉴 -->

<script>
    // gnb 서브메뉴 표시
    document.querySelectorAll('#gnb > ul > li').forEach(item => {
        item.addEventListener('mouseenter', (e) => {
            const subMenu = e.currentTarget.querySelector('.sub_menu01');
            if(subMenu) {
                subMenu.style.display = 'block';
            }
        });
        
        item.addEventListener('mouseleave', (e) => {
            const subMenu = e.currentTarget.querySelector('.sub_menu01');
            if(subMenu) {
                // 서브메뉴에 마우스가 있는지 확인
                if(!subMenu.matches(':hover')) {
                    subMenu.style.display = 'none';
                }
            }
        });
    });

    // 서브메뉴 마우스 이벤트
    document.querySelectorAll('.sub_menu01').forEach(subMenu => {
        subMenu.addEventListener('mouseleave', (e) => {
            e.currentTarget.style.display = 'none';
        });
    });
    
    // 모바일 메뉴 열기 
    document.querySelector('#m_menu > a').addEventListener('click', () => {
        const mWrap = document.querySelector('.m_wrap');
        const mBack = document.querySelector('.m_back');
        
        mWrap.style.transition = 'transform 0.3s ease';
        
        mWrap.style.transform = 'translateX(100%)';
        mBack.style.transform = 'translateX(100%)';
        
        mWrap.style.display = 'block';
        mBack.style.display = 'block';
        
        setTimeout(() => {
            mWrap.style.transform = 'translateX(0)';
            mBack.style.transform = 'translateX(0)';
        }, 0);
    });

    // 모바일 메뉴 닫기
    document.querySelector('.m_x').addEventListener('click', () => {
        const mWrap = document.querySelector('.m_wrap');
        const mBack = document.querySelector('.m_back');
        
        mWrap.style.transform = 'translateX(100%)';
        mBack.style.transform = 'translateX(100%)';
        
        setTimeout(() => {
            mWrap.style.display = 'none';
            mBack.style.display = 'none';
        }, 300);
    });

    document.querySelector('.m_back').addEventListener('click', () => {
        const mWrap = document.querySelector('.m_wrap');
        const mBack = document.querySelector('.m_back');
        
        mWrap.style.transform = 'translateX(100%)';
        mBack.style.transform = 'translateX(100%)';
        
        setTimeout(() => {
            mWrap.style.display = 'none';
            mBack.style.display = 'none';
        }, 300);
    });

    // 모바일 메뉴 서브메뉴 토글
    document.querySelectorAll('.m_list > ul > li > a').forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            
            const currentLi = e.currentTarget.parentElement;
            const currentSubMenu = currentLi.querySelector('.m_sub');
            
            // 다른 모든 서브메뉴 닫기
            document.querySelectorAll('.m_list > ul > li > .m_sub').forEach(subMenu => {
                if(subMenu !== currentSubMenu) {
                    subMenu.style.maxHeight = '0';
                    subMenu.style.display = 'none';
                }
            });
            
            // 현재 클릭한 메뉴의 서브메뉴 토글
            if(currentSubMenu) {
                if(currentSubMenu.style.display === 'block') {
                    currentSubMenu.style.maxHeight = '0';
                    currentSubMenu.style.display = 'none';
                } else {
                    currentSubMenu.style.transition = 'max-height 0.2s ease';
                    currentSubMenu.style.display = 'block';
                    currentSubMenu.style.maxHeight = currentSubMenu.scrollHeight + 10 + 'px';
                }
            }
        });
    });
</script>