            });
        });

        // 각 닫기 버튼에 이벤트 추가
        modalCloseBtn?.addEventListener('click', () => {
            attendanceModal.style.display = 'none';
        });
        modalCancelBtn?.addEventListener('click', () => {
            attendanceModal.style.display = 'none';
        });

        // 모달 외부 영역 클릭 시 닫기
        window.addEventListener('click', (e) => {
            if (e.target === attendanceModal) {
                attendanceModal.style.display = 'none';
            }
        });

        // 주간/월간 스케줄 버튼 클릭 이벤트
        function changeDateType(type) {
            const scheduleDate = document.querySelector('.schedule_date');
            scheduleDate.type = type;
        }
        // 주간/월간 스케줄 버튼 클릭 이벤트
        document.getElementById('btn_schedule_week').addEventListener('click', () => {
            document.getElementById('btn_schedule_week').classList.add('btn_active01');
            document.getElementById('btn_schedule_month').classList.remove('btn_active01');
        });

        document.getElementById('btn_schedule_month').addEventListener('click', () => {
            document.getElementById('btn_schedule_month').classList.add('btn_active01');
            document.getElementById('btn_schedule_week').classList.remove('btn_active01');
        });

        // 버튼 클릭 시 btn_textactive 클래스 토글
        function handleButtonClick(clickedButton) {
            // 모든 버튼에서 btn_textactive 클래스 제거
            const buttons = document.querySelectorAll('.schedule_top ul li button');
            buttons.forEach(button => {
                button.classList.remove('btn_textactive01');
            });
            
            // 클릭된 버튼에만 btn_textactive 클래스 추가
            clickedButton.classList.add('btn_textactive01');
        }

        // 등원 버튼 클릭 시 btn_active 클래스 토글
        function toKinderButtonClick(clickedButton) {
            // toKinder_btn 안의 모든 버튼에서 btn_active 클래스 제거
            const buttons = document.querySelectorAll('.toKinder_btn li button');
            buttons.forEach(button => {
                button.classList.remove('btn_active01');
            });
            // 클릭된 버튼에만 btn_active 클래스 추가
            clickedButton.classList.add('btn_active01');
        }

        // 하원 버튼 클릭 시 btn_active 클래스 토글 
        function toHomeButtonClick(clickedButton) {
            // toHome_btn 안의 모든 버튼에서 btn_active 클래스 제거
            const buttons = document.querySelectorAll('.toHome_btn li button');
            buttons.forEach(button => {
                button.classList.remove('btn_active01');
            });
            // 클릭된 버튼에만 btn_active 클래스 추가
            clickedButton.classList.add('btn_active01');
        }
    </script>
</html>