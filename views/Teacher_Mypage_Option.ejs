                                                    <option value="오전 5시">오전 5시</option>
                                                    <option value="오전 6시">오전 6시</option>
                                                    <option value="오전 7시" selected>오전 7시</option>
                                                    <option value="오전 8시">오전 8시</option>
                                                    <option value="오전 9시">오전 9시</option>
                                                </select>
                                                <p class="p_14px">까지 모든 알림 끄기</p>
