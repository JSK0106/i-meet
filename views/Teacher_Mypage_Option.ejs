                                        <div class="option_notice">
                                            <ul class="flex_start">
                                                <li class="flex_start">
                                                    <input type="checkbox" name="공지사항알림" value="알림" class="checkbox02" disabled>
                                                    <p class="p_14px">알림</p>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="form_contents flex_start">
                                        <label for="정보변경 알림">정보변경 알림</label>
                                        <div class="option_change">
                                            <ul class="flex_start">
                                                <li class="flex_start">
