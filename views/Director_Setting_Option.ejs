                                                </li>
                                                <li class="flex_start">
                                                    <input type="checkbox" name="출결제한" value="일요일" class="checkbox" disabled>
                                                    <p class="p_14px">일요일</p>
                                                </li>
                                            </ul>
                                            <p class="p_12px">선택 요일에는 RFID 인식 정보가 전송되지 않아요</p>
                                        </div>
                                    </div>
                                    <div class="form_contents flex_start">
                                        <label for="출결제한 시간">출결제한 시간</label>
                                        <div class="option_notset">
                                            <div class="flex_start">
                                                <p class="p_14px">금일</p>
                                                <select name="not_time01" class="select_03" disabled>
