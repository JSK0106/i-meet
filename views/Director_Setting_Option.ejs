                                                    <option value="0분">0분</option>
                                                    <option value="15분">15분</option>
                                                    <option value="30분" selected>30분</option>
                                                    <option value="45분">45분</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form_contents flex_start">
                                        <label for="학부모 알림">학부모 알림</label>
                                        <div class="option_parents">
                                            <ul class="flex_start">
                                                <li class="flex_start">
                                                    <input type="checkbox" name="학부모알림" value="등원" class="checkbox" disabled>
                                                    <p class="p_14px">등원 시</p>
                                                </li>
                                                <li class="flex_start">
                                                    <input type="checkbox" name="학부모알림" value="하원" class="checkbox" disabled>
                                                    <p class="p_14px">하원 시</p>
                                                </li>
                                            </ul>
                                            <p class="p_12px">체크 표시를 하면 메시지가 전송돼요</p>
                                        </div>
                                    </div>
                                    <div class="form_contents flex_start">
