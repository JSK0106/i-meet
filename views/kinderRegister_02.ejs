        <!-- 주소 찾기 모달 -->
        <div id="addressSearch_modal" class="modal_container hidden">
            <%-/* 주소 찾기 모달*/ include ("./templates/addressSearch_modal") %>
        </div>
        <!-- 주소 찾기 모달 -->

        <!-- footer -->
        <footer id="footer">
            <%-/*footer 불러오기*/ include ("./templates/footer") %>
        </footer>
        <!-- footer -->
    </body>

    <script>
        //입력값 삭제
        function clearInputText(button) {
            const label = button.closest('label'); // 버튼 기준으로 가장 가까운 label 찾기
            const contentsBox = label.parentElement; // label의 부모 = .contents_box
            const input = contentsBox.querySelector('input'); // 그 안의 input 찾기

            if (input) {
                input.value = ''; // 입력값 비우기
                input.focus(); // 포커스 주기 (선택사항)
            }
        }

        const addressSearchModal = document.getElementById('addressSearch_modal');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const modalCancelBtn = document.getElementById('modalCancelBtn');
        const btnAddress = document.querySelectorAll('.btn_kinder');

        // 프로필 클릭 시 모달 열기
        btnAddress.forEach(gridContent => {
            gridContent.addEventListener('click', () => {
                addressSearchModal.style.display = 'flex';
            });
        });

        // 각 닫기 버튼에 이벤트 추가
        modalCloseBtn?.addEventListener('click', () => {
            addressSearchModal.style.display = 'none';
        });
        modalCancelBtn?.addEventListener('click', () => {
            addressSearchModal.style.display = 'none';
        });

        // 모달 외부 영역 클릭 시 닫기
        window.addEventListener('click', (e) => {
            if (e.target === addressSearchModal) {
                addressSearchModal.style.display = 'none';
            }
        });

        //원 찾기 주소
        const areaList = {
            "서울특별시": ["강남구", "강동구", "강북구", "강서구", "관악구", "광진구", "구로구", "금천구", "노원구", "도봉구", "동대문구", "동작구", "마포구", "서대문구", "서초구", "성동구", "성북구", "송파구", "양천구", "영등포구", "용산구", "은평구", "종로구", "중구", "중랑구"],
            "부산광역시": ["강서구", "금정구", "기장군", "남구", "동구", "동래구", "부산진구", "북구", "사상구", "사하구", "서구", "수영구", "연제구", "영도구", "중구", "해운대구"],
            "대구광역시": ["남구", "달서구", "달성군", "동구", "북구", "서구", "수성구", "중구"],
            "인천광역시": ["강화군", "계양구", "남동구", "동구", "미추홀구", "부평구", "서구", "연수구", "옹진군", "중구"],
            "광주광역시": ["광산구", "남구", "동구", "북구", "서구"],
            "대전광역시": ["대덕구", "동구", "서구", "유성구", "중구"],
            "울산광역시": ["남구", "동구", "북구", "울주군", "중구"],
            "세종특별자치시": ["세종시 전체"],
            "경기도": ["가평군", "고양시", "과천시", "광명시", "광주시", "구리시", "군포시", "김포시", "남양주시", "동두천시", "부천시", "성남시", "수원시", "시흥시", "안산시", "안성시", "안양시", "양주시", "양평군", "여주시", "연천군", "오산시", "용인시", "의왕시", "의정부시", "이천시", "파주시", "평택시", "포천시", "하남시", "화성시"],
            "강원도": ["강릉시", "고성군", "동해시", "삼척시", "속초시", "양구군", "양양군", "영월군", "원주시", "인제군", "정선군", "철원군", "춘천시", "태백시", "평창군", "홍천군", "화천군", "횡성군"],
            "충청북도": ["괴산군", "단양군", "보은군", "영동군", "옥천군", "음성군", "제천시", "증평군", "진천군", "청주시", "충주시"],
            "충청남도": ["계룡시", "공주시", "금산군", "논산시", "당진시", "보령시", "부여군", "서산시", "서천군", "아산시", "연기군", "예산군", "천안시", "청양군", "태안군", "홍성군"],
            "전라북도": ["고창군", "군산시", "김제시", "남원시", "무주군", "부안군", "순창군", "완주군", "익산시", "임실군", "장수군", "전주시", "정읍시", "진안군"],
            "전라남도": ["강진군", "고흥군", "곡성군", "광양시", "구례군", "나주시", "담양군", "목포시", "무안군", "보성군", "순천시", "신안군", "여수시", "영광군", "영암군", "완도군", "장성군", "장흥군", "진도군", "함평군", "해남군", "화순군"],
            "경상북도": ["경산시", "경주시", "고령군", "구미시", "군위군", "김천시", "문경시", "봉화군", "상주시", "성주군", "안동시", "영덕군", "영양군", "영주시", "영천시", "예천군", "울릉군", "울진군", "의성군", "청도군", "청송군", "칠곡군", "포항시"],
            "경상남도": ["거제시", "거창군", "고성군", "김해시", "남해군", "밀양시", "사천시", "산청군", "양산시", "의령군", "진주시", "창녕군", "창원시", "통영시", "하동군", "함안군", "함양군", "합천군"],
            "제주특별자치도": ["서귀포시", "제주시"]
        };

        const address01 = document.getElementById("address01");
        const address02 = document.getElementById("address02");
        const searchBtn = document.querySelector(".btn_search");
        const keywordInput = document.getElementById("kinder_name");
        const resultList = document.querySelector("#kinder_list ul");
        const resultCount = document.querySelector("#kinder_list .p_16px");
        const detailInput = document.getElementById("kinder_addressDetail");
        const modalRegisterBtn = document.getElementById("modalRegisterBtn");
        const finalAddressInput = document.getElementById("kinder_address");

        let selectedAddress = ""; // 선택된 기본 주소 저장

        // 지역 선택 시 시군구 업데이트
        address01.addEventListener("change", () => {
            const selectedCity = address01.value;
            address02.innerHTML = `<option disabled selected>시/군구</option>`;
            if (areaList[selectedCity]) {
                areaList[selectedCity].forEach(gu => {
                    const option = document.createElement("option");
                    option.value = gu;
                    option.textContent = gu;
                    address02.appendChild(option);
                });
            }
        });

        // 임시 데이터 (실제 서비스에선 서버로부터 받아야 함)
        const allData = [
            {
                name: "e편한산들어린이집",
                address: "경기도 남양주시 오남읍 양지로 240번길 37 관리동",
                phone: "031-514-1001"
            },
            {
                name: "행복한유치원",
                address: "서울특별시 강남구 논현로 85길 12",
                phone: "02-512-3456"
            }
        ];

        // 검색 버튼
        searchBtn.addEventListener("click", () => {
            const selectedCity = address01.value;
            const selectedGu = address02.value;
            const keyword = keywordInput.value.trim();

            const filtered = allData.filter(item => {
            return item.address.includes(selectedCity) &&
                    item.address.includes(selectedGu) &&
                    (item.name.includes(keyword) || item.address.includes(keyword));
            });

            resultList.innerHTML = "";
            resultCount.textContent = `총 ${filtered.length}개`;

            if (filtered.length === 0) {
                resultList.innerHTML = `<li><p class="p_14px">검색 결과가 없습니다.</p></li>`;
            } 
            else {
                filtered.forEach(item => {
                    const li = document.createElement("li");
                    li.className = "flex_between";
                    li.innerHTML = `
                    <div class="kinder_wrap">
                        <p class="p_14px">${item.name}</p>
                        <div class="kinder_address_num flex_start_column">
                        <p class="p_12px">${item.address}</p>
                        <p class="p_12px">${item.phone}</p>
                        </div>
                    </div>
                    <button class="btn_blueline02" data-address="${item.address}">선택</button>
                    `;
                    resultList.appendChild(li);
                });

                // 선택 버튼에 이벤트 연결
                document.querySelectorAll(".btn_blueline02").forEach(btn => {
                    btn.addEventListener("click", () => {
                        selectedAddress = btn.getAttribute("data-address");
                        alert(`선택된 주소: ${selectedAddress}`);
                    });
                });
            }
        });

        // 등록 버튼 클릭
        modalRegisterBtn.addEventListener("click", () => {
            if (!selectedAddress) {
                alert("주소를 먼저 선택해 주세요.");
                return;
            }

            const detail = detailInput.value.trim();
            if (!detail) {
                alert("상세 주소를 입력해 주세요.");
                return;
            }

            finalAddressInput.value = `${selectedAddress} ${detail}`;
            alert("주소가 입력되었습니다.");
            addressSearchModal.style.display = 'none';
        });

        // 입력 초기화 함수
        function clearInputText(btn) {
            const input = btn.closest(".search_wrap").querySelector("input");
            if (input) input.value = "";
        }
    </script>
</html>