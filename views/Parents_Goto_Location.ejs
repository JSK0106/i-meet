        // 일괄등록 버튼 클릭 시 모달 열기
        kinderChange.addEventListener('click', () => {
            kinderChangeModal.style.display = 'flex';
        });

        // 각 닫기 버튼에 이벤트 추가
        modalCloseBtn?.addEventListener('click', () => {
            kinderChangeModal.style.display = 'none';
        });
        modalCancelBtn?.addEventListener('click', () => {
            kinderChangeModal.style.display = 'none';
        });

        // 모달 외부 영역 클릭 시 닫기
