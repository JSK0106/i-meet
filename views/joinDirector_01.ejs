    <script>
        //입력값 삭제
        function clearInputText(button) {
            const label = button.closest('label'); // 버튼 기준으로 가장 가까운 label 찾기
            const contentsBox = label.parentElement; // label의 부모 = .contents_box
            const input = contentsBox.querySelector('input'); // 그 안의 input 찾기

            if (input) {
                input.value = ''; // 입력값 비우기
                input.focus(); // 포커스 주기 (선택사항)
            }
        }
    </script>
