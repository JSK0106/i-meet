    <script>
        const inviteRoleTeacher = document.getElementById('invite_role_teacher');
        const inviteRoleParents = document.getElementById('invite_role_parents');
        const inviteRoleDriver = document.getElementById('invite_role_driver');
        const inviteInfoTeacher = document.querySelectorAll('.invite_info_teacher');
        const inviteInfoParents = document.querySelectorAll('.invite_info_parents');
        const inviteInfoDriver = document.querySelectorAll('.invite_info_driver');

        document.addEventListener('DOMContentLoaded', function() {
            const inviteRoleLinks = document.querySelectorAll('.invite_role a');
            inviteRoleLinks.forEach(link => {
                link.addEventListener('click', function() {
                    inviteRoleLinks.forEach(link => link.classList.remove('role_active'));
                    this.classList.add('role_active');
                    if (link == inviteRoleTeacher) {
                        inviteInfoTeacher.forEach(info => info.style.display = 'block');
                        inviteInfoParents.forEach(info => info.style.display = 'none');
                        inviteInfoDriver.forEach(info => info.style.display = 'none');
                    }
                    else if (link == inviteRoleParents) {
                        inviteInfoTeacher.forEach(info => info.style.display = 'none');
                        inviteInfoParents.forEach(info => info.style.display = 'block');
                        inviteInfoDriver.forEach(info => info.style.display = 'none');
                    }
                    else if (link == inviteRoleDriver) {
                        inviteInfoTeacher.forEach(info => info.style.display = 'none');
                        inviteInfoParents.forEach(info => info.style.display = 'none');
                        inviteInfoDriver.forEach(info => info.style.display = 'block');
                    }
                });
            });
        });
    </script>
