    <script>
        const kinderChangeModal = document.getElementById('kinderChange_modal');
        const modalModifyBtn = document.getElementById('modalModifyBtn');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const modalCancelBtn = document.getElementById('modalCancelBtn');
        const kinderChange = document.getElementById('kinder_change');

        // 일괄등록 버튼 클릭 시 모달 열기
        kinderChange.addEventListener('click', () => {
            kinderChangeModal.style.display = 'flex';
        });

        // 각 닫기 버튼에 이벤트 추가
        modalCloseBtn?.addEventListener('click', () => {
            kinderChangeModal.style.display = 'none';
        });
        modalCancelBtn?.addEventListener('click', () => {
            kinderChangeModal.style.display = 'none';
        });

        // 모달 외부 영역 클릭 시 닫기
        window.addEventListener('click', (e) => {
            if (e.target === assignTeacherModal) {
                kinderChangeModal.style.display = 'none';
            }
        });
        
        document.getElementById('upload_button').addEventListener('click', function () {
            document.getElementById('file_input').click();
        });
        
        document.getElementById('file_input').addEventListener('change', function (event) {
            const file = event.target.files[0];
        
            if (!file) return;
        
            const validTypes = ['image/jpeg', 'image/png', 'image/jpg'];
            const maxSize = 10 * 1024 * 1024; // 10MB
        
            if (!validTypes.includes(file.type)) {
                alert('JPG, JPEG, PNG 파일만 업로드할 수 있습니다.');
                return;
            }
        
            if (file.size > maxSize) {
                alert('10MB 미만의 파일만 업로드할 수 있습니다.');
                return;
            }
        
            const reader = new FileReader();
            reader.onload = function (e) {
                const imageUrl = e.target.result;
                const imgTag = document.querySelector('#profile_img img');
                imgTag.src = imageUrl;
        
                document.getElementById('photo_name').value = file.name;
            };
            reader.readAsDataURL(file);
        });
    </script>
